	email {$ACME_EMAIL}
}

{$DOMAIN} {
	root * /srv/app
	encode gzip zstd

	@api path /api/v1* /actuator*
	reverse_proxy @api backend:8080

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		Cross-Origin-Resource-Policy same-origin
	}

	file_server
	try_files {path} /index.html
}
